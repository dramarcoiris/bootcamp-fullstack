{
    "extends": [
        "stylelint-config-standard",
        "stylelint-config-recess-order"
    ],
    "rules": {
        "selector-class-pattern": [
            "^([a-zA-Z0-9]+-?)*[a-zA-Z0-9_-]*$",
            {
                "resolveNestedSelectors": true,
                "message": "Esperado nombre de clase siguiendo el patrón personalizado"
            }
        ]
    }
}